{
  "name": "modelhub",
  "version": "1.0.0",
  "description": "Hub unificado para múltiplos modelos de IA com API compatível OpenAI, chat integrado e gerenciamento de credenciais",
  "author": "ModelHub Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Geeks-Zone/modelhub.git"
  },
  "bugs": {
    "url": "https://github.com/Geeks-Zone/modelhub/issues"
  },
  "homepage": "https://github.com/Geeks-Zone/modelhub#readme",
  "keywords": [
    "ai",
    "llm",
    "openai",
    "anthropic",
    "google",
    "gemini",
    "chat",
    "api",
    "gateway",
    "proxy",
    "nextjs",
    "typescript",
    "prisma",
    "neon",
    "vercel"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "modelhub": "./scripts/modelhub-cli.mjs"
  },
  "scripts": {
    "build": "next build",
    "build:vercel": "node scripts/vercel-build.mjs",
    "predev": "pnpm prisma:generate",
    "dev": "next dev",
    "lint": "eslint",
    "postinstall": "pnpm prisma:generate",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config prisma.config.ts",
    "prisma:migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
    "prisma:push": "prisma db push --config prisma.config.ts",
    "start": "next start",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:duckai-live": "node scripts/run-duckai-live-test.mjs",
    "openclaw:setup": "node ./scripts/modelhub-cli.mjs openclaw setup",
    "openclaw:doctor": "node ./scripts/modelhub-cli.mjs doctor",
    "typecheck": "tsc --noEmit",
    "vercel:env:pull": "vercel env pull .env.local -y --environment development",
    "vercel:env:pull:preview": "vercel env pull .env.vercel.preview.local -y --environment preview",
    "vercel:env:pull:production": "vercel env pull .env.vercel.production.local -y --environment production",
    "vercel:env:diff": "node scripts/vercel-env-sync.mjs",
    "vercel:env:sync": "node scripts/vercel-env-sync.mjs --pull"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@neondatabase/auth": "0.2.0-beta.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.14",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^5.7.284",
    "pg": "^8.20.0",
    "puppeteer": "^24.42.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "postcss": "^8.5.12",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vite": "7.3.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "better-auth": "1.4.9",
      "vite": "7.3.2",
      "@hono/node-server": "1.19.13"
    }
  }
}
