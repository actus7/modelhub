generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  isActive  Boolean  @default(true)
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys             ApiKey[]
  providerCredentials ProviderCredential[]
  cloudConnections    CloudConnection[]
  cloudDeployments    CloudDeployment[]
  usageLogs           UsageLog[]
  conversations       Conversation[]
  settings            UserSettings?
  memories            UserMemory[]
  routingConfig       RoutingConfig?
  budget              UserBudget?
}

model ApiKey {
  id         String    @id @default(cuid())
  key        String    @unique
  prefix     String
  label      String    @default("default")
  userId     String
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  expiresAt  DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs UsageLog[]

  @@index([key])
  @@index([userId])
}

model ProviderCredential {
  id              String   @id @default(cuid())
  userId          String
  providerId      String
  credentialKey   String
  credentialValue String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId, credentialKey])
  @@index([userId, providerId])
}

model CloudConnection {
  id                       String   @id @default(cuid())
  userId                   String
  provider                 String
  label                    String   @default("Render")
  token                    String
  externalUserId           String?
  externalUserEmail        String?
  externalOrganizationId   String?
  externalOrganizationName String?
  modelhubApiKey           String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deployments CloudDeployment[]

  @@unique([userId, provider])
  @@index([userId, provider])
}

model CloudDeployment {
  id                   String   @id @default(cuid())
  userId               String
  connectionId         String
  provider             String
  name                 String
  status               String
  externalAppId        String
  externalAppName      String
  externalServiceId    String
  externalDeploymentId String?
  publicUrl            String?
  image                String
  region               String
  instanceType         String
  port                 Int
  error                String?
  config               Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection CloudConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([userId, provider])
  @@index([userId, status])
}

model UsageLog {
  id             String   @id @default(cuid())
  userId         String
  apiKeyId       String?
  providerId     String
  modelId        String?
  endpoint       String?
  statusCode     Int      @default(200)
  /// Trecho da resposta de erro (JSON/texto) para diagnóstico no dashboard; ausente em sucessos e em logs antigos.
  errorDetail    String?
  inputTokens    Int?
  outputTokens   Int?
  costUsd        Float?
  durationMs     Int?
  routingTier    String?
  routingReason  String?
  taskCategory   String?
  baselineModelId   String?
  baselineCostUsd   Float?
  createdAt      DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([apiKeyId])
}

model Conversation {
  id         String   @id @default(cuid())
  userId     String
  title      String   @default("Nova conversa")
  providerId String?
  modelId    String?
  archived   Boolean  @default(false)
  shareToken String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
  attachments ConversationAttachment[]

  @@index([userId, updatedAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  parts          Json?
  parentId       String?
  branchIndex    Int      @default(0)
  createdAt      DateTime @default(now())

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments  ConversationAttachment[]
  reactions    MessageReaction[]
  parent       Message?          @relation("MessageBranches", fields: [parentId], references: [id], onDelete: SetNull)
  children     Message[]         @relation("MessageBranches")

  @@index([conversationId, createdAt])
  @@index([parentId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  type      String   // "thumbs_up" | "thumbs_down"
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
}

model UserSettings {
  id                    String  @id @default(cuid())
  userId                String  @unique
  customInstructionsAbout String? // "What should the AI know about you?"
  customInstructionsStyle String? // "How should the AI respond?"
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserMemory {
  id        String   @id @default(cuid())
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model RoutingConfig {
  id                 String   @id @default(cuid())
  userId             String   @unique
  complexityEnabled  Boolean  @default(false)
  taskRoutingEnabled Boolean  @default(false)
  /// JSON: Record<string, {providerId: string, modelId: string, fallbacks?: Array<{providerId: string, modelId: string}>}> — keyed by tier name or task category
  tiers              Json     @default("{}")
  taskOverrides      Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserBudget {
  id               String   @id @default(cuid())
  userId           String   @unique
  periodType       String   @default("monthly")
  limitUsd         Float?
  alertThreshold   Float    @default(0.8)
  blocksRequests   Boolean  @default(false)
  baselineModelId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConversationAttachment {
  id               String   @id @default(cuid())
  conversationId   String
  messageId        String?
  kind             String
  mimeType         String
  fileName         String
  byteSize         Int
  blob             Bytes
  extractedText    String?
  extractionStatus String
  createdAt        DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message?     @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([messageId])
}
